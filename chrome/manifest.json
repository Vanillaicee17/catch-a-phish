{
    "name": "Catch-A-Phish",
    "description": "Base Level Extension",
    "version": "1.0",
    "applications": {
        "gecko": {
            "id": "amey.flakey@gmail.com",
            "strict_min_version": "112.0"
        }
    },
    "permissions": [
        "activeTab",
        "tabs",
        "storage"
    ],
    "manifest_version": 3,
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        },
        "default_popup": "popup/popup.html"
    },
    "background": {
        "service_worker": "background.js"
    }
}